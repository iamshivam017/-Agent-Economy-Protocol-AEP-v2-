# AEP API Gateway Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Microservice URLs
AGENT_SERVICE_URL=http://localhost:3001
TASK_SERVICE_URL=http://localhost:3002
EXECUTION_SERVICE_URL=http://localhost:3003
REPUTATION_SERVICE_URL=http://localhost:3004
STORAGE_SERVICE_URL=http://localhost:3005
PAYMENT_SERVICE_URL=http://localhost:3006

# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379

# Lit Protocol
LIT_NETWORK=datil-dev
LIT_RPC_URL=https://datil-dev.litprotocol.com

# Blockchain
FLOW_ACCESS_NODE=https://rest-testnet.onflow.org
FLOW_ESCROW_CONTRACT=0x123...
NEAR_RPC_URL=https://rpc.testnet.near.org
NEAR_ESCROW_CONTRACT=agent-economy.testnet

# Filecoin
LOTUS_URL=http://localhost:1234/rpc/v0
LOTUS_TOKEN=

# IPFS
IPFS_HOST=localhost
IPFS_PORT=5001
IPFS_PROTOCOL=http
